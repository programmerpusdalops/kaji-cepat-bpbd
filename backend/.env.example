# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bpbd_disaster
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=supersecret_change_this_in_production
JWT_EXPIRE=1d

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
